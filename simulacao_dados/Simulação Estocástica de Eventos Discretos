import random
import statistics

# Semente fixa para garantir reprodutibilidade
random.seed(42)

def gerar_pacientes(qtd=1000):
    pacientes = []
    for _ in range(qtd):
        idade = int(random.gauss(40, 20)) # Distribuição normal de idades (média 40, desvio 20)
        idade = max(1, min(idade, 95)) # Limitando entre 1 e 95 anos

        tem_trauma = random.random() < 0.05
        tem_sangramento = random.random() < 0.10

        # 70% dos casos em UPAs são queixas leves (Verde/Azul) - Fonte: Literatura (GBCR)
        if random.random() < 0.70:
            dor_principal = random.choice(['Garganta', 'Costas', 'Nenhuma', 'Mialgia'])
            oxigenio = random.triangular(95, 100, 98) # Mais realista que uniform
        else:
            dor_principal = random.choice(['Coração', 'Rins', 'Abdome', 'Cabeça', 'Falta de Ar'])
            oxigenio = random.triangular(85, 99, 94)

        prefere_presencial = random.random() < 0.20

        pacientes.append({
            'idade': idade,
            'tem_trauma': tem_trauma,
            'tem_sangramento': tem_sangramento,
            'oxigenio': oxigenio,
            'dor_principal': dor_principal,
            'prefere_presencial': prefere_presencial
        })
    return pacientes

def classificar_paciente(p):
    # Lógica baseada em gatilhos primários do Manchester
    if p['tem_trauma'] or p['dor_principal'] in ['Coração', 'Falta de Ar'] or p['oxigenio'] < 90:
        return 'VERMELHO'
    elif p['tem_sangramento'] or p['dor_principal'] == 'Rins':
        return 'AMARELO'
    elif p['idade'] >= 65:
        return 'AMARELO' # Estatuto do Idoso
    elif p['dor_principal'] in ['Garganta', 'Costas', 'Nenhuma', 'Mialgia']:
        return 'VERDE'
    else:
        return 'AZUL'

def simular():
    print("Iniciando Simulação Estocástica de Eventos (Método de Monte Carlo)...")
    pacientes = gerar_pacientes(1000)

    casos_graves = 0
    casos_leves_presencial = 0
    casos_auditoria_digital = 0

    tempos_espera_tradicional = []
    tempos_espera_hibrido = []

    for p in pacientes:
        cor = classificar_paciente(p)

        # --- CENÁRIO A: TRADICIONAL ---
        if cor in ['VERMELHO', 'AMARELO']:
            tempo_tradicional = random.gauss(20, 5) # Média 20 min para graves
        else:
            tempo_tradicional = random.gauss(180, 40) # Média 3h para leves

        tempos_espera_tradicional.append(max(1, tempo_tradicional))

        # --- CENÁRIO B: HÍBRIDO (Com IA e Auditor Digital) ---
        if cor in ['VERMELHO', 'AMARELO']:
            casos_graves += 1
            tempo_hibrido = random.gauss(10, 3) # Graves atendidos mais rápido (fila andou)
        else:
            if p['prefere_presencial']:
                casos_leves_presencial += 1
                tempo_hibrido = random.gauss(45, 15) # Fila presencial menor
            else:
                casos_auditoria_digital += 1
                tempo_hibrido = random.gauss(5, 1.5) # Auditoria resolve em 5 min

        tempos_espera_hibrido.append(max(1, tempo_hibrido))

    # --- RESULTADOS VISUAIS ---
    print("\n" + "="*60)
    print("📊 RESULTADOS DA SIMULAÇÃO ESTOCÁSTICA")
    print("="*60)
    print(f"Total de Pacientes Triados: {len(pacientes)}")
    print(f"Encaminhados p/ Presencial (Graves/Prioridade): {casos_graves}")
    print(f"Encaminhados p/ Presencial (Leves preferem médico): {casos_leves_presencial}")
    print(f"Resolvidos pela Auditoria Digital (IA): {casos_auditoria_digital}")

    carga_reduzida = (casos_auditoria_digital / len(pacientes)) * 100
    print(f"\n📉 Redução Absoluta da Carga Presencial: {carga_reduzida:.1f}%")

    media_tradicional = statistics.mean(tempos_espera_tradicional)
    media_hibrida = statistics.mean(tempos_espera_hibrido)

    print(f"\n⏱️ Tempo Médio Global (Cenário Tradicional): {media_tradicional:.1f} minutos")
    print(f"⚡ Tempo Médio Global (Cenário IA Híbrido): {media_hibrida:.1f} minutos")

    economia_tempo = media_tradicional - media_hibrida
    print(f"\n🚀 O sistema reduziu o Lead Time em {economia_tempo:.1f} minutos por paciente.")
    print("="*60)

if __name__ == "__main__":
    simular()